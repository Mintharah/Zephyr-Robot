/* boards/blackpill.overlay */

/ {
    aliases {
        tb-uart   = &usart1;            /* host comms (command channel)      */
        loop-uart = &usart2;            /* UART self-loopback: PA2 TX -> PA3 RX */
        loop-spi  = &spi1;              /* SPI self-loopback: PA7 MOSI -> PA6 MISO */
        pwm-gen   = &pwm_gen_pin;       /* PWM out — TIM3 CH3 / PB0          */
        pwm-cap   = &pwm_cap_pin;       /* PWM in  — TIM1 CH1 / PA8 capture  */
    };

    /* DIO pins */
    zephyr,user {
        dio-gpios = <&gpiob 3 GPIO_ACTIVE_HIGH>, /* DIO0 = PB3 */
                    <&gpiob 4 GPIO_ACTIVE_HIGH>, /* DIO1 = PB4 */
                    <&gpiob 5 GPIO_ACTIVE_HIGH>, /* DIO2 = PB5 */
                    <&gpiob 6 GPIO_ACTIVE_HIGH>, /* DIO3 = PB6 */
                    <&gpioa 1 GPIO_ACTIVE_HIGH>; /* DIO4 = PA1 -> ADC drive (jumper PA1->PA0) */

        io-channels = <&adc1 0>;           /* PA0 = AIN0 */
    };

    pwm_out: pwm_out {
        compatible = "pwm-leds";
        pwm_gen_pin: pwm_gen_pin {
            pwms = <&timers3_pwm 2 1000000 PWM_POLARITY_NORMAL>;
            /* CH3 = index 2 (0-based), default period 1 ms */
        };
    };

    pwm_in: pwm_in {
        compatible = "pwm-leds";
        pwm_cap_pin: pwm_cap_pin {
            pwms = <&timers1_pwm 0 1000000 PWM_POLARITY_NORMAL>;
            /* CH1 = index 0 (0-based) */
        };
    };
};


/* Host comms UART */
&usart1 {
    status = "okay";
    current-speed = <115200>;
    pinctrl-0 = <&usart1_tx_pa9 &usart1_rx_pa10>;
    pinctrl-names = "default";
};

/* UART self-loopback (PA2 TX jumpered to PA3 RX) */
&usart2 {
    status = "okay";
    current-speed = <115200>;
    pinctrl-0 = <&usart2_tx_pa2 &usart2_rx_pa3>;
    pinctrl-names = "default";
};

/* SPI self-loopback (PA7 MOSI jumpered to PA6 MISO) */
&spi1 {
    status = "okay";
    pinctrl-0 = <&spi1_sck_pa5 &spi1_miso_pa6 &spi1_mosi_pa7>;
    pinctrl-names = "default";
    cs-gpios = <&gpioa 4 GPIO_ACTIVE_LOW>;
};

/* ADC */
&adc1 {
    status = "okay";
    #address-cells = <1>;
    #size-cells = <0>;
    pinctrl-0 = <&adc1_in0_pa0>;
    pinctrl-names = "default";

    channel@0 {
        reg = <0>;
        zephyr,gain = "ADC_GAIN_1";
        zephyr,reference = "ADC_REF_VDD_1"; 
        zephyr,vref-mv = <3300>;
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,input-positive = <0>; 
        zephyr,resolution = <12>;
    };
};

/* TIM3 CH3 drives PB0 for PWM output */
&timers3 {
    status = "okay";
    st,prescaler = <99>;   /* 100 MHz / 100 = 1 MHz tick */

    timers3_pwm: pwm {
        status = "okay";
        pinctrl-0 = <&tim3_ch3_pb0>;
        pinctrl-names = "default";
    };
};

/* TIM1 CH1 on PA8 captures the incoming PWM for CMD:PWM_GET */
&timers1 {
    status = "okay";
    st,prescaler = <99>;   /* 1 MHz tick — matches the output timer */

    timers1_pwm: pwm {
        status = "okay";
        pinctrl-0 = <&tim1_ch1_pa8>;
        pinctrl-names = "default";
        four-channel-capture-support;
    };
};
